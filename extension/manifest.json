{
  "manifest_version": 3,
  "name": "TuneConsole session bridge",
  "version": "0.1.3",
  "description": "Bridges your signed-in YouTube Music session to the local TuneConsole app so it can read and manage your library.",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_title": "TuneConsole session bridge"
  },
  "permissions": ["cookies", "tabs", "alarms", "scripting"],
  "host_permissions": [
    "https://music.youtube.com/*",
    "http://127.0.0.1:8765/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["suppress_unload_main.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["observer_main.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["nowplaying_main.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ]
}
